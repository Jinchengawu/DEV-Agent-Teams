FROM node:22-slim AS base
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV NEXT_PUBLIC_GATEWAY_URL=http://gateway:8400

COPY package.json pnpm-workspace.yaml ./
COPY packages/dashboard/package.json packages/dashboard/package.json

RUN corepack enable && pnpm install --frozen-lockfile --filter @dev-agent/dashboard... --prod=false

COPY packages/dashboard packages/dashboard

RUN pnpm --filter @dev-agent/dashboard run build

EXPOSE 3000
CMD ["pnpm", "--filter", "@dev-agent/dashboard", "start"]
