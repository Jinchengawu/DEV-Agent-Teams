# DEV-Agent-Teams production environment template
# Copy to deploy/.env.production and fill real values.

NODE_ENV=production

# Keep guarded by default. Set MODEL_SPEND_GUARD=0 only after budget approval.
MODEL_SPEND_GUARD=1
ALLOW_LIVE_MODEL=0

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8400
AGENT_DB_PATH=/data
AUDIT_FILE=/logs/audit.log

# Dashboard
PORT=3000
GATEWAY_URL=http://gateway:8400
NEXT_PUBLIC_GATEWAY_URL=http://gateway:8400

# Model provider
MODEL_PROVIDER=deepseek
MODEL_NAME=deepseek-v4-pro
MODEL_BASE_URL=https://api.deepseek.com/v1
API_KEY=replace-with-provider-key

# Auth
OMA_AUTH_ENABLED=false
JWT_SECRET=replace-with-random-32-byte-secret

# Hermes role agent ports
FRONTEND_AGENT_PORT=8002
BACKEND_AGENT_PORT=8003
TESTING_AGENT_PORT=8004
DEVOPS_AGENT_PORT=8005
PM_AGENT_PORT=8006
PROJECT_ADMIN_AGENT_PORT=8007
