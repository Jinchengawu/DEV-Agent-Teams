#!/bin/bash

# DEV-Agent CLI 工具
# 使用方法: ./dev-agent <command> [options]

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VERSION="0.1.0"
OPEN_FRAMEWORK_ROOT="${OPEN_FRAMEWORK_ROOT:-/Users/zhuizhui/网盘同步/work/学习/AI/Open-Agent-Teams}"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 显示帮助
show_help() {
    echo -e "${BLUE}DEV-Agent CLI${NC} v${VERSION}"
    echo ""
    echo "用法: ./dev-agent <command> [options]"
    echo ""
    echo "命令:"
    echo "  ${GREEN}start${NC}           启动所有 Agent 和 Gateway"
    echo "  ${GREEN}stop${NC}            停止所有服务"
    echo "  ${GREEN}status${NC}          查看服务状态"
    echo "  ${GREEN}doctor${NC}          深度诊断本地 MVP 就绪状态"
    echo "  ${GREEN}test${NC}            运行测试"
    echo "  ${GREEN}logs${NC}            查看日志"
    echo "  ${GREEN}help${NC}            显示帮助信息"
    echo ""
    echo "示例:"
    echo "  ./dev-agent start"
    echo "  ./dev-agent status"
    echo "  ./dev-agent doctor"
    echo "  ./dev-agent doctor --json"
    echo "  ./dev-agent test"
}

stop_screen_sessions() {
    local session="$1"
    screen -ls 2>/dev/null \
        | awk -v name="\\.${session}[[:space:]]" '$0 ~ name { print $1 }' \
        | while read -r screen_id; do
            [ -n "$screen_id" ] && screen -S "$screen_id" -X quit >/dev/null 2>&1 || true
        done
}

# 启动服务
start_services() {
    echo -e "${BLUE}🚀 启动 DEV-Agent 服务...${NC}"

    # 启动 Hermes Agent、Gateway 和 Dashboard
    echo -e "${YELLOW}启动本地服务...${NC}"
    bash "$SCRIPT_DIR/scripts/start-all.sh"

    echo -e "${GREEN}✅ 所有服务已启动${NC}"
}

# 停止服务
stop_services() {
    echo -e "${BLUE}🛑 停止 DEV-Agent 服务...${NC}"

    # 停止 screen 会话（如果由 start-all.sh 启动）。先关会话可以带走 tee/bash/pnpm
    # 进程树，后续端口和命令模式清理用于处理历史残留进程。
    for session in hermes-frontend hermes-backend hermes-testing hermes-devops hermes-pm hermes-project-admin dev-agent-gateway dev-agent-dashboard; do
        stop_screen_sessions "$session"
    done
    
    # 停止 Gateway (端口 8400)
    echo -e "${YELLOW}停止 Gateway...${NC}"
    lsof -ti:8400 | xargs kill -9 2>/dev/null || true
    pkill -f "$SCRIPT_DIR/packages/gateway.*pnpm dev" 2>/dev/null || true
    pkill -f "$SCRIPT_DIR/packages/gateway.*tsx" 2>/dev/null || true
    
    # 停止各 Agent (当前 Hermes 端口 8002-8007；兼容旧端口 8201-8206)
    echo -e "${YELLOW}停止 Agent 实例...${NC}"
    for port in 8002 8003 8004 8005 8006 8007 8201 8202 8203 8204 8205 8206; do
        lsof -ti:$port | xargs kill -9 2>/dev/null || true
    done
    
    # 停止 Hermes 进程
    pkill -f "hermes gateway run" 2>/dev/null || true
    
    # 停止 Dashboard (端口 3000)
    echo -e "${YELLOW}停止 Dashboard...${NC}"
    lsof -ti:3000 | xargs kill -9 2>/dev/null || true
    pkill -f "$SCRIPT_DIR/packages/dashboard.*pnpm dev" 2>/dev/null || true
    pkill -f "$SCRIPT_DIR/packages/dashboard.*next dev" 2>/dev/null || true
    
    echo -e "${GREEN}✅ 所有服务已停止${NC}"
}

print_json_field() {
    local file="$1"
    local field="$2"

    python3 - "$file" "$field" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as f:
    data = json.load(f)

cur = data
for part in sys.argv[2].split("."):
    if isinstance(cur, list):
        cur = cur[int(part)]
    elif isinstance(cur, dict):
        cur = cur.get(part)
    else:
        cur = None
        break

print("" if cur is None else cur)
PY
}

show_team_health_summary() {
    local tmp_file
    tmp_file="$(mktemp)"

    echo ""
    echo "Team Coordination:"
    if curl -fsS "http://127.0.0.1:8400/agent-health" > "$tmp_file" 2>/dev/null; then
        local online total skills live_ready spend_guard backfill_ready
        online="$(print_json_field "$tmp_file" "onlineCount")"
        total="$(print_json_field "$tmp_file" "totalAgents")"
        skills="$(print_json_field "$tmp_file" "totalSkills")"
        live_ready="$(print_json_field "$tmp_file" "livePipelineReady")"
        spend_guard="$(print_json_field "$tmp_file" "modelSpendGuard")"
        backfill_ready="$(print_json_field "$tmp_file" "codexBackfillReady")"

        if [ "$online" = "$total" ] && [ -n "$total" ] && { [ "$live_ready" = "True" ] || { [ "$spend_guard" = "True" ] && [ "$backfill_ready" = "True" ]; }; }; then
            echo -e "  ${GREEN}✅ Gateway Agent Health: online=${online}/${total}, skills=${skills}, livePipelineReady=${live_ready}, modelSpendGuard=${spend_guard}, codexBackfillReady=${backfill_ready}${NC}"
        else
            echo -e "  ${YELLOW}⚠ Gateway Agent Health: online=${online:-0}/${total:-0}, skills=${skills:-0}, livePipelineReady=${live_ready:-unknown}, modelSpendGuard=${spend_guard:-unknown}, codexBackfillReady=${backfill_ready:-unknown}${NC}"
        fi
    else
        echo -e "  ${RED}❌ Gateway Agent Health 不可访问${NC}"
    fi

    if curl -fsS "http://127.0.0.1:3000/api/health" > "$tmp_file" 2>/dev/null; then
        local dashboard_online dashboard_total dashboard_gateway dashboard_live
        dashboard_online="$(print_json_field "$tmp_file" "onlineCount")"
        dashboard_total="$(print_json_field "$tmp_file" "totalAgents")"
        dashboard_gateway="$(print_json_field "$tmp_file" "gatewayOnline")"
        dashboard_live="$(print_json_field "$tmp_file" "livePipelineReady")"
        echo -e "  ${GREEN}✅ Dashboard API Health: gateway=${dashboard_gateway}, online=${dashboard_online}/${dashboard_total}, livePipelineReady=${dashboard_live}${NC}"
    else
        echo -e "  ${RED}❌ Dashboard API Health 不可访问${NC}"
    fi

    if curl -fsS "http://127.0.0.1:3000/api/delivery-gate/latest" > "$tmp_file" 2>/dev/null; then
        local gate_ok gate_report gate_summary
        gate_ok="$(print_json_field "$tmp_file" "ok")"
        gate_report="$(print_json_field "$tmp_file" "report")"
        gate_summary="$(print_json_field "$tmp_file" "summary")"

        if [ "$gate_ok" = "True" ]; then
            echo -e "  ${GREEN}✅ Delivery Gate: ${gate_summary} (${gate_report})${NC}"
        else
            echo -e "  ${YELLOW}⚠ Delivery Gate: ${gate_summary:-unknown} (${gate_report:-no-report})${NC}"
        fi
    else
        echo -e "  ${YELLOW}⚠ Delivery Gate 报告不可访问；请运行 scripts/e2e-delivery-gate.sh${NC}"
    fi

    if curl -fsS "http://127.0.0.1:3000/api/team-loop/status" > "$tmp_file" 2>/dev/null; then
        local loop_ok checks instance_id project_id latest_doc
        loop_ok="$(print_json_field "$tmp_file" "ok")"
        checks="$(print_json_field "$tmp_file" "checkSummary")"
        instance_id="$(print_json_field "$tmp_file" "latestInstance.id")"
        project_id="$(print_json_field "$tmp_file" "latestInstance.projectId")"
        latest_doc="$(print_json_field "$tmp_file" "documents.latestDocument.id")"

        if [ "$loop_ok" = "True" ]; then
            echo -e "  ${GREEN}✅ Team Loop Evidence: checks=${checks}, instance=${instance_id}, project=${project_id}, latestDoc=${latest_doc}${NC}"
        else
            echo -e "  ${YELLOW}⚠ Team Loop Evidence: checks=${checks:-unknown}, instance=${instance_id:-none}, project=${project_id:-none}${NC}"
        fi
    else
        echo -e "  ${YELLOW}⚠ Team Loop 状态不可访问${NC}"
    fi

    if [ -d "$OPEN_FRAMEWORK_ROOT/.git" ]; then
        local open_head open_remote
        open_head="$(git -C "$OPEN_FRAMEWORK_ROOT" rev-parse --short HEAD 2>/dev/null || true)"
        open_remote="$(git -C "$OPEN_FRAMEWORK_ROOT" rev-parse --short origin/main 2>/dev/null || true)"

        if [ -n "$open_head" ] && [ "$open_head" = "$open_remote" ]; then
            echo -e "  ${GREEN}✅ Open Framework Sync: HEAD=${open_head}, origin/main=${open_remote}${NC}"
        else
            echo -e "  ${YELLOW}⚠ Open Framework Sync: HEAD=${open_head:-unknown}, origin/main=${open_remote:-unknown}${NC}"
        fi
    else
        echo -e "  ${YELLOW}⚠ Open Framework Sync: repo not found at ${OPEN_FRAMEWORK_ROOT}${NC}"
    fi

    rm -f "$tmp_file"
}

