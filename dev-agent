DOCTOR_FAILED=0

doctor_pass() {
    echo -e "  ${GREEN}✅ $1${NC}"
}

doctor_fail() {
    echo -e "  ${RED}❌ $1${NC}"
    DOCTOR_FAILED=1
}

doctor_info() {
    echo -e "  ${BLUE}ℹ $1${NC}"
}

doctor_check_command() {
    local command_name="$1"
    local label="$2"

    if command -v "$command_name" >/dev/null 2>&1; then
        doctor_pass "$label: $($command_name --version 2>/dev/null | head -n 1) ($(command -v "$command_name"))"
    else
        doctor_fail "$label 未安装或不在 PATH"
    fi
}

doctor_check_native_module() {
    local package_dir="$1"
    local module_name="$2"
    local label="$3"

    if [ ! -d "$package_dir/node_modules" ]; then
        doctor_fail "$label 缺少 node_modules: $package_dir"
        return
    fi

    if (cd "$package_dir" && node -e "require(process.argv[1])" "$module_name") >/dev/null 2>&1; then
        doctor_pass "$label native module 可加载: $module_name"
    else
        doctor_fail "$label native module 不兼容: $module_name；请用当前 Node 重新 pnpm install"
    fi
}

doctor_check_http() {
    local url="$1"
    local label="$2"

    if curl -fsS "$url" >/dev/null 2>&1; then
        doctor_pass "$label 可访问: $url"
    else
        doctor_fail "$label 不可访问: $url"
    fi
}

doctor_check_port() {
    local port="$1"
    local label="$2"

    if lsof -tiTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1; then
        doctor_pass "$label 端口监听中: :$port"
    else
        doctor_fail "$label 端口未监听: :$port"
    fi
}

doctor_check_agent_health() {
    local tmp_file
    tmp_file="$(mktemp)"

    if ! curl -fsS "http://127.0.0.1:8400/agent-health" > "$tmp_file" 2>/dev/null; then
        rm -f "$tmp_file"
        doctor_fail "Gateway Agent Health 不可访问"
        return
    fi

    if python3 - "$tmp_file" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as f:
    data = json.load(f)

agents = data.get("agents", [])
mode_ok = data.get("livePipelineReady") is True or (
    data.get("modelSpendGuard") is True and data.get("codexBackfillReady") is True
)
ok = (
    mode_ok
    and data.get("onlineCount") == data.get("totalAgents") == 6
    and len(agents) == 6
    and all(agent.get("online") is True for agent in agents)
)

raise SystemExit(0 if ok else 1)
PY
    then
        local summary
        summary="$(python3 - "$tmp_file" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as f:
    data = json.load(f)

print(f"online={data.get('onlineCount')}/{data.get('totalAgents')} liveReady={data.get('livePipelineReady')} modelSpendGuard={data.get('modelSpendGuard')} codexBackfillReady={data.get('codexBackfillReady')}")
PY
)"
        doctor_pass "Agent 团队就绪: $summary"
    else
        doctor_fail "Agent 团队未完全就绪；请检查 ./dev-agent status 和 Gateway 日志"
    fi

    rm -f "$tmp_file"
}

doctor_check_open_framework_sync() {
    if [ ! -d "$OPEN_FRAMEWORK_ROOT/.git" ]; then
        doctor_fail "Open-Agent-Teams 仓库不可访问: $OPEN_FRAMEWORK_ROOT"
        return
    fi

    local open_head open_remote dirty_count
    open_head="$(git -C "$OPEN_FRAMEWORK_ROOT" rev-parse --short HEAD 2>/dev/null || true)"
    open_remote="$(git -C "$OPEN_FRAMEWORK_ROOT" rev-parse --short origin/main 2>/dev/null || true)"
    dirty_count="$(git -C "$OPEN_FRAMEWORK_ROOT" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"

    if [ -n "$open_head" ] && [ "$open_head" = "$open_remote" ]; then
        doctor_pass "Open 框架同步: HEAD=$open_head origin/main=$open_remote dirty=$dirty_count"
    else
        doctor_fail "Open 框架未同步: HEAD=${open_head:-unknown} origin/main=${open_remote:-unknown}"
    fi
}

run_doctor() {
    echo -e "${BLUE}🩺 DEV-Agent MVP Doctor${NC}"
    echo ""

    echo "Runtime:"
    doctor_check_command node "Node.js"
    doctor_check_command pnpm "pnpm"
    doctor_check_command hermes "Hermes"
    doctor_info "当前 PATH Node: $(command -v node 2>/dev/null || echo missing)"

    echo ""
    echo "Native modules:"
    doctor_check_native_module "$SCRIPT_DIR/packages/core" "better-sqlite3" "Core session/document store"
    doctor_check_native_module "$SCRIPT_DIR/packages/dashboard" "better-sqlite3" "Dashboard kanban/document APIs"

    echo ""
    echo "HTTP services:"
    for port in 8002 8003 8004 8005 8006 8007; do
        doctor_check_port "$port" "Hermes Agent"
    done
    doctor_check_http "http://127.0.0.1:8400/health" "Gateway"
    doctor_check_http "http://127.0.0.1:3000/api/health" "Dashboard API"
    doctor_check_agent_health

    echo ""
    echo "Framework sync:"
    doctor_check_open_framework_sync

    echo ""
    if [ "$DOCTOR_FAILED" -eq 0 ]; then
        echo -e "${GREEN}✅ Doctor 通过：本地 Team Coordination Loop 具备 MVP 测试条件${NC}"
    else
        echo -e "${RED}❌ Doctor 未通过：请先修复上述失败项${NC}"
        return 1
    fi
}

run_doctor_json() {
    SCRIPT_DIR="$SCRIPT_DIR" OPEN_FRAMEWORK_ROOT="$OPEN_FRAMEWORK_ROOT" python3 <<'PY'
import json
import os
import socket
import subprocess
import sys
import urllib.error
import urllib.request

root = os.environ["SCRIPT_DIR"]
open_framework_root = os.environ["OPEN_FRAMEWORK_ROOT"]

def command_check(name):
    path = shutil_which(name)
    if not path:
        return {"ok": False, "path": None, "version": None}
    try:
        version = subprocess.check_output([name, "--version"], text=True, stderr=subprocess.STDOUT, timeout=5).splitlines()[0]
    except Exception as exc:
        version = f"version unavailable: {exc}"
    return {"ok": True, "path": path, "version": version}

def shutil_which(name):
    for directory in os.environ.get("PATH", "").split(os.pathsep):
        candidate = os.path.join(directory, name)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None

def native_module_check(package_dir, module):
    full_dir = os.path.join(root, package_dir)
    if not os.path.isdir(os.path.join(full_dir, "node_modules")):
        return {"ok": False, "module": module, "path": full_dir, "error": "node_modules missing"}
    try:
        subprocess.check_output(
            ["node", "-e", "require(process.argv[1])", module],
            cwd=full_dir,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=10,
        )
        return {"ok": True, "module": module, "path": full_dir}
    except subprocess.CalledProcessError as exc:
        return {"ok": False, "module": module, "path": full_dir, "error": exc.output.strip()}
    except Exception as exc:
        return {"ok": False, "module": module, "path": full_dir, "error": str(exc)}

def port_check(port):
    try:
        with socket.create_connection(("127.0.0.1", port), timeout=2):
            return {"ok": True, "port": port}
    except OSError as exc:
        return {"ok": False, "port": port, "error": str(exc)}

def http_json(url):
    try:
        with urllib.request.urlopen(url, timeout=5) as response:
            body = response.read().decode("utf-8")
            return {"ok": 200 <= response.status < 300, "status": response.status, "data": json.loads(body)}
    except urllib.error.HTTPError as exc:
        return {"ok": False, "status": exc.code, "error": exc.read().decode("utf-8", "replace")}
    except Exception as exc:
        return {"ok": False, "status": None, "error": str(exc)}

def git_value(repo, *args):
    return subprocess.check_output(
        ["git", "-C", repo, *args],
        text=True,
        stderr=subprocess.STDOUT,
        timeout=5,
    ).strip()

def open_framework_sync_check(repo):
    if not os.path.isdir(os.path.join(repo, ".git")):
        return {"ok": False, "path": repo, "error": "repo not found"}
    try:
        head = git_value(repo, "rev-parse", "--short", "HEAD")
        remote = git_value(repo, "rev-parse", "--short", "origin/main")
        dirty = git_value(repo, "status", "--porcelain")
        dirty_count = 0 if not dirty else len(dirty.splitlines())
        return {
            "ok": bool(head) and head == remote,
            "path": repo,
            "head": head,
            "remote": remote,
            "dirtyCount": dirty_count,
        }
    except subprocess.CalledProcessError as exc:
        return {"ok": False, "path": repo, "error": exc.output.strip()}
    except Exception as exc:
        return {"ok": False, "path": repo, "error": str(exc)}

runtime = {
    "node": command_check("node"),
    "pnpm": command_check("pnpm"),
    "hermes": command_check("hermes"),
}
native_modules = {
    "coreBetterSqlite3": native_module_check("packages/core", "better-sqlite3"),
    "dashboardBetterSqlite3": native_module_check("packages/dashboard", "better-sqlite3"),
}
ports = {str(port): port_check(port) for port in [8002, 8003, 8004, 8005, 8006, 8007]}
gateway_health = http_json("http://127.0.0.1:8400/health")
dashboard_health = http_json("http://127.0.0.1:3000/api/health")
agent_health = http_json("http://127.0.0.1:8400/agent-health")
open_framework_sync = open_framework_sync_check(open_framework_root)

agent_data = agent_health.get("data") if agent_health.get("ok") else {}
agent_mode_ready = (
    isinstance(agent_data, dict)
    and (
        agent_data.get("livePipelineReady") is True
        or (agent_data.get("modelSpendGuard") is True and agent_data.get("codexBackfillReady") is True)
    )
)
agent_ready = (
    isinstance(agent_data, dict)
    and agent_mode_ready
    and agent_data.get("onlineCount") == agent_data.get("totalAgents") == 6
    and isinstance(agent_data.get("agents"), list)
    and len(agent_data.get("agents")) == 6
    and all(agent.get("online") is True for agent in agent_data.get("agents"))
)

ok = (
    all(item["ok"] for item in runtime.values())
    and all(item["ok"] for item in native_modules.values())
    and all(item["ok"] for item in ports.values())
    and gateway_health.get("ok") is True
    and dashboard_health.get("ok") is True
    and agent_ready
    and open_framework_sync.get("ok") is True
)

payload = {
    "ok": ok,
    "runtime": runtime,
    "nativeModules": native_modules,
    "ports": ports,
    "gateway": {
        "ok": gateway_health.get("ok"),
        "status": gateway_health.get("status"),
        "agents": (gateway_health.get("data") or {}).get("agents") if isinstance(gateway_health.get("data"), dict) else None,
    },
    "dashboard": {
        "ok": dashboard_health.get("ok"),
        "status": dashboard_health.get("status"),
        "gatewayOnline": (dashboard_health.get("data") or {}).get("gatewayOnline") if isinstance(dashboard_health.get("data"), dict) else None,
    },
    "agentHealth": {
        "ok": agent_ready,
        "onlineCount": agent_data.get("onlineCount") if isinstance(agent_data, dict) else None,
        "totalAgents": agent_data.get("totalAgents") if isinstance(agent_data, dict) else None,
        "livePipelineReady": agent_data.get("livePipelineReady") if isinstance(agent_data, dict) else None,
        "modelSpendGuard": agent_data.get("modelSpendGuard") if isinstance(agent_data, dict) else None,
        "codexBackfillReady": agent_data.get("codexBackfillReady") if isinstance(agent_data, dict) else None,
    },
    "openFrameworkSync": open_framework_sync,
    "checkedAt": int(__import__("time").time() * 1000),
}

print(json.dumps(payload, ensure_ascii=False, indent=2))
raise SystemExit(0 if ok else 1)
PY
}

# 运行测试
run_tests() {
    echo -e "${BLUE}🧪 运行测试...${NC}"
    bash "$SCRIPT_DIR/scripts/test-gateway.sh"
}

# 查看日志
show_logs() {
    echo -e "${BLUE}📋 查看日志...${NC}"
    tail -f ~/.dev-agent/logs/audit.log 2>/dev/null || echo "暂无日志"
}

# 主函数
main() {
    case ${1:-help} in
        start)
            start_services
            ;;
        stop)
            stop_services
            ;;
        status)
            show_status
            ;;
        doctor)
            if [ "${2:-}" = "--json" ]; then
                run_doctor_json
            else
                run_doctor
            fi
            ;;
        test)
            run_tests
            ;;
        logs)
            show_logs
            ;;
        help|--help|-h)
            show_help
            ;;
        version|--version|-v)
            echo "DEV-Agent CLI v${VERSION}"
            ;;
        *)
            echo -e "${RED}未知命令: $1${NC}"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
