# DEV-Agent-Teams 环境变量配置
# 复制此文件为 .env 并填写真实值
# ⚠️ 勿将 .env 文件提交到 Git

# 模型配置
MODEL_PROVIDER=deepseek
MODEL_NAME=deepseek-v4-pro
MODEL_BASE_URL=https://api.deepseek.com/v1

# API Keys（如需要）
API_KEY=sk-your-provider-key

# Kimi 开放平台: https://platform.moonshot.cn

# Agent 端口配置
FRONTEND_AGENT_PORT=8002
BACKEND_AGENT_PORT=8003
TESTING_AGENT_PORT=8004
DEVOPS_AGENT_PORT=8005
PM_AGENT_PORT=8006
PROJECT_ADMIN_AGENT_PORT=8007

# OMA 配置
OMA_AUTH_ENABLED=false

# JWT 认证
JWT_SECRET=change-me-to-a-random-secret-string
