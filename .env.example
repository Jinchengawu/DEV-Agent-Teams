# DEV-Agent-Teams 环境变量配置
# 复制此文件为 .env 并填写真实值
# ⚠️ 勿将 .env 文件提交到 Git

# 模型配置
MODEL_PROVIDER=your_provider
MODEL_NAME=your_model_name
MODEL_BASE_URL=your_api_base_url

# API Keys（如需要）
# API_KEY=your_api_key_here

# Agent 端口配置
FRONTEND_AGENT_PORT=8201
BACKEND_AGENT_PORT=8202
TESTING_AGENT_PORT=8203
DEVOPS_AGENT_PORT=8204

# OpenClaw 配置
OPENCLAW_AUTH_ENABLED=false
