# DEV-Agent-Teams 环境变量配置
# 复制此文件为 .env 并填写真实值
# ⚠️ 勿将 .env 文件提交到 Git

# 模型配置
MODEL_PROVIDER=deepseek
MODEL_NAME=deepseek-v4-pro[1m]
MODEL_BASE_URL=https://api.deepseek.com/anthropic

# API Keys（如需要）
# API_KEY=your_api_key_here

# Agent 端口配置
FRONTEND_AGENT_PORT=8201
BACKEND_AGENT_PORT=8202
TESTING_AGENT_PORT=8203
DEVOPS_AGENT_PORT=8204
PM_AGENT_PORT=8205

# OpenClaw 配置
OPENCLAW_AUTH_ENABLED=false
